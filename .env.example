# VeritasNode Environment Configuration
# Copy: cp .env.example .env   then fill secrets for non-development.

# --- Application ---
# APP_NAME: service title
APP_NAME=VeritasNode API
# APP_VERSION: semver string
APP_VERSION=0.1.0
# DEBUG: true for local verbose logs
DEBUG=true
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development

# --- Database (required format: postgresql+asyncpg://...) ---
DATABASE_URL=postgresql+asyncpg://veritas:veritas123@localhost:5432/veritas

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- IPFS ---
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# --- Stellar / Soroban ---
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=CCER22QT2GQJAPWQKBBGZ7CF2S74OGK2POAFOP5VAW6546ODEJLVRHTY

# --- AI / ML ---
MODEL_PATH=./models/verifier
CONFIDENCE_THRESHOLD=0.85

# --- Security (REQUIRED in production — never ship the default secret) ---
SECRET_KEY=change-me-in-production-use-a-real-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Chainlink ---
CHAINLINK_API_URL=http://localhost:6688
