# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Blockchain Configuration
SOROBAN_NETWORK=testnet
SOROBAN_RPC_URL=http://localhost:8000
SOROBAN_SECRET_KEY=your_secret_key_here
CONTRACT_ID=your_deployed_contract_id

# Database Configuration
DATABASE_URL=postgresql://veritas:veritas123@localhost:5432/veritas
REDIS_URL=redis://localhost:6379

# IPFS Configuration
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Chainlink Configuration
CHAINLINK_API_URL=http://localhost:6688
CHAINLINK_JOB_ID=your_job_id
CHAINLINK_API_KEY=your_chainlink_api_key

# AI/ML Configuration
TENSORFLOW_MODEL_PATH=./models/
OPENAI_API_KEY=your_openai_api_key
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_key

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your_secret_key_for_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:8080
NEXT_PUBLIC_CONTRACT_ID=your_contract_id

# External APIs
GITHUB_API_TOKEN=your_github_token
SATELLITE_API_KEY=your_satellite_imagery_api_key

# Monitoring & Logging
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090

# Development
NODE_ENV=development
DEBUG=true
