# VeritasNode Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=VeritasNode
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql+asyncpg://veritas:veritas123@localhost:5432/veritas

# Redis
REDIS_URL=redis://localhost:6379

# IPFS
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# Stellar / Soroban
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=

# AI / ML
MODEL_PATH=./models/verifier
CONFIDENCE_THRESHOLD=0.85

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=change-me-in-production-use-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Chainlink
CHAINLINK_API_URL=http://localhost:6688

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:8080
NEXT_PUBLIC_STELLAR_NETWORK=testnet
